# Backend service-scoped environment (used for local `uvicorn` runs outside Docker).
# When running via `docker compose up`, the root .env takes precedence.

ENV=development
LOG_LEVEL=INFO

DATABASE_URL=postgresql+asyncpg://stadiumpulse:change_me_in_local_env@localhost:5432/stadiumpulse
REDIS_URL=redis://localhost:6379/0

ANTHROPIC_API_KEY=sk-ant-replace-me
ANTHROPIC_MODEL_DEFAULT=claude-sonnet-4-6
ANTHROPIC_MODEL_ESCALATION=claude-opus-4-8

JWT_SECRET=change_me_to_a_long_random_string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

API_V1_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:3000
