# ---------------------------------------------------------------------------
# StadiumPulse — root environment configuration
# Copy to .env and fill in real values. Never commit the real .env file.
# Individual services also read backend/.env.example and frontend/.env.example
# for service-scoped variables; this file drives docker-compose.
# ---------------------------------------------------------------------------

# --- Environment -----------------------------------------------------------
ENV=development
LOG_LEVEL=INFO

# --- Postgres ----------------------------------------------------------------
POSTGRES_USER=stadiumpulse
POSTGRES_PASSWORD=change_me_in_local_env
POSTGRES_DB=stadiumpulse
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://stadiumpulse:change_me_in_local_env@postgres:5432/stadiumpulse

# --- Redis ---------------------------------------------------------------
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# --- LLM (Google Gemini) -----------------------------------------------------
LLM_PROVIDER=gemini
GEMINI_API_KEY=AIzaSy...
GEMINI_MODEL_DEFAULT=gemini-3.5-flash
# Used only by Tournament Memory's embed-and-store step (backend/app/services/embeddings.py).
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
# Match this to your actual key's quota (check https://ai.dev/rate-limit) so
# the app self-throttles instead of burning a tight daily budget on 429s.
# A free-tier key can be as low as 5/minute.
LLM_RATE_LIMIT_PER_MINUTE=60

# --- Auth ------------------------------------------------------------------
JWT_SECRET=change_me_to_a_long_random_string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# --- API ---------------------------------------------------------------------
API_V1_PREFIX=/api/v1
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:3000
# Per-client-IP request budget (SlowAPI, backend/app/main.py).
HTTP_RATE_LIMIT=30/minute

# --- Frontend ------------------------------------------------------------
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws
